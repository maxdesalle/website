{{- /* Section-scoped podcast feed: iTunes + MRSS. Applies only to /podcast/index.xml. */ -}}
{{- $author := .Params.author | default site.Params.author -}}
{{- $ownerEmail := .Params.owner_email | default site.Params.email -}}
{{- $image := .Params.image -}}
{{- $summary := .Params.summary | default .Description | default site.Params.description -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd" xmlns:media="http://search.yahoo.com/mrss/" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Title | default site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <language>{{ .Params.language | default site.LanguageCode | default "en-us" }}</language>
    <description>{{ $summary }}</description>
    <itunes:summary>{{ $summary }}</itunes:summary>
    <itunes:author>{{ $author }}</itunes:author>
    <itunes:type>{{ .Params.itunes_type | default "episodic" }}</itunes:type>
    <itunes:explicit>{{ if .Params.explicit }}true{{ else }}false{{ end }}</itunes:explicit>
    {{- with $image }}
    <itunes:image href="{{ . }}" />{{ end }}
    {{- with $ownerEmail }}
    <itunes:owner><itunes:name>{{ $author }}</itunes:name><itunes:email>{{ . }}</itunes:email></itunes:owner>
    <managingEditor>{{ . }}{{ with $author }} ({{ . }}){{ end }}</managingEditor>{{ end }}
    {{- with .Params.itunes_category }}
    <itunes:category text="{{ . }}">{{ with $.Params.itunes_subcategory }}<itunes:category text="{{ . }}" />{{ end }}</itunes:category>{{ end }}
    <generator>Hugo -- gohugo.io</generator>
    {{- if not .Date.IsZero }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}
    {{- with .OutputFormats.Get "RSS" }}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}{{ end }}
    {{- range .RegularPages }}
    {{- $audioBytes := .Params.audio_bytes | default 0 -}}
    {{- $audioType := .Params.audio_type | default "audio/mpeg" -}}
    {{- $videoBytes := .Params.video_bytes | default 0 -}}
    {{- $videoType := .Params.video_type | default "video/mp4" -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid isPermaLink="false">{{ .Params.guid | default .File.UniqueID }}</guid>
      <description><![CDATA[{{ .Content }}]]></description>
      <itunes:summary>{{ .Description | default .Summary }}</itunes:summary>
      {{- with .Params.duration }}
      <itunes:duration>{{ . }}</itunes:duration>{{ end }}
      {{- with .Params.episode }}
      <itunes:episode>{{ . }}</itunes:episode>{{ end }}
      {{- with .Params.season }}
      <itunes:season>{{ . }}</itunes:season>{{ end }}
      <itunes:explicit>{{ if .Params.explicit }}true{{ else }}false{{ end }}</itunes:explicit>
      {{- with .Params.audio_url }}
      <enclosure url="{{ . }}" length="{{ $audioBytes }}" type="{{ $audioType }}" />{{ end }}
      {{- with .Params.video_url }}
      <media:content url="{{ . }}" fileSize="{{ $videoBytes }}" type="{{ $videoType }}" medium="video" />{{ end }}
    </item>{{ end }}
  </channel>
</rss>
